+    for i in 0..len {
+        unsafe {
+            std::ptr::copy_nonoverlapping(init_bytes, data_ptr.add(i * element_size), element_size);
+        }
+    }
+
+    let ptr = Box::leak(buf.into_boxed_slice()).as_ptr();
+    unsafe {
+        *(ret as *mut u64) = ptr as u64;
+    }
+    0
+}
