+    }
+
+    fn execute(&self, args: &[Value]) -> Result<Value, String> {
+        expect_arity(self.name(), args, self.arity())?;
+        let x = match &args[0] {
+            Value::F64(x) => *x,
+            other => return Err(format!("`sqrt` expected F64, got {other:?}")),
+        };
+        Ok(Value::F64(x.sqrt()))
